# 复制本文件为 .env，填入你的 DeepSeek Key，然后运行：node --env-file=.env server.js
# .env 已被 .gitignore 忽略，不会上传到 GitHub。

DEEPSEEK_API_KEY=在这里填你的_deepseek_key

# 可选：如果 DeepSeek 调整了接口地址或模型名，在这里改即可，无需改代码
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
# 完整报告用的模型。deepseek-v4-pro 生成较慢、容易超时，默认也用 flash。
# 若你账号有可用的更强模型，把确切名称填到下面这行（并注意它可能更慢）。
DEEPSEEK_MODEL_PRO=deepseek-v4-flash

# 本地端口（可选）
PORT=3000

# ===== ZPay（易支付）微信/支付宝收款 =====
# 在 ZPay 商户后台获取 PID（商户ID）与 KEY（商户密钥），填到下面两行。
ZPAY_PID=在这里填你的_ZPay_PID
ZPAY_KEY=在这里填你的_ZPay_密钥
# ZPay 接口域名（一般默认即可；以你后台显示的为准）
ZPAY_HOST=https://z-pay.cn
# 你的站点公网地址：ZPay 异步回调和支付后跳回都用它。
# 本地测试可留 http://localhost:3000，但本地收不到 ZPay 公网回调（用结算页的"模拟支付"测流程）。
# 部署到正式域名后改成： https://offerscope.org
SITE_URL=http://localhost:3000
